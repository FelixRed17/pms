<% content_for :title, "Launch New Cycle" %>

<div class="review-cycle-form rounded-3xl border border-slate-200 bg-white p-6 shadow-shell sm:p-8">
  <%= form_with model: @review_cycle, url: reviewcycles_path, scope: :review_cycle, class: "space-y-8" do |form| %>
    <div class="grid gap-8 xl:grid-cols-[minmax(0,1.45fr)_minmax(320px,0.75fr)]">
      <div class="space-y-6">
        <section class="rounded-3xl border border-slate-200 bg-slate-50 p-6">
          <div class="flex items-center justify-between gap-4">
            <div>
              <p class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-400">General Information</p>
              <h4 class="mt-2 text-lg font-semibold text-slate-900">Cycle details</h4>
            </div>
            <span class="rounded-full bg-orange-100 px-3 py-1 text-xs font-semibold uppercase tracking-[0.2em] text-orange-700">Required</span>
          </div>

          <div class="mt-6 grid gap-5 md:grid-cols-2">
            <div class="md:col-span-2">
              <%= form.label :name, "Cycle Name", class: "mb-2 block text-sm font-medium text-slate-700" %>
              <%= form.text_field :name, placeholder: "Q3 Performance Review / Engineering", class: "block w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900 shadow-sm outline-none transition focus:border-orange-500 focus:ring-4 focus:ring-orange-100" %>
            </div>

            <div>
              <%= form.label :start_on, "Start Date", class: "mb-2 block text-sm font-medium text-slate-700" %>
              <%= form.date_field :start_on, class: "block w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900 shadow-sm outline-none transition focus:border-orange-500 focus:ring-4 focus:ring-orange-100" %>
            </div>

            <div>
              <%= form.label :end_on, "End Date", class: "mb-2 block text-sm font-medium text-slate-700" %>
              <%= form.date_field :end_on, class: "block w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900 shadow-sm outline-none transition focus:border-orange-500 focus:ring-4 focus:ring-orange-100" %>
            </div>
          </div>
        </section>

        <section class="rounded-3xl border border-slate-200 bg-slate-50 p-6">
          <div class="flex items-center justify-between gap-4">
            <div>
              <p class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-400">Review Participants</p>
              <h4 class="mt-2 text-lg font-semibold text-slate-900">People assigned to this cycle</h4>
            </div>
            <span class="rounded-full bg-slate-900 px-3 py-1 text-xs font-semibold uppercase tracking-[0.2em] text-white">HR Controlled</span>
          </div>

          <div class="mt-6 space-y-5">
            <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-card">
              <%= form.label :reviewee_id, "Add Reviewee", class: "block text-sm font-medium text-slate-700" %>
              <p class="mt-1 text-sm text-slate-500">Select the employee whose review cycle is being launched.</p>
              <%= form.collection_select :reviewee_id, @people, :id, :email, { prompt: "Select reviewee" }, { class: "mt-4 block w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900 shadow-sm outline-none transition focus:border-orange-500 focus:ring-4 focus:ring-orange-100" } %>
            </div>

            <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-card">
              <%= render "reviewcycles/peer_reviewer_selector", form: form, people: @people %>
            </div>

            <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-card">
              <%= form.label :manager_id, "Add Manager Reviewer", class: "block text-sm font-medium text-slate-700" %>
              <p class="mt-1 text-sm text-slate-500">Assign the manager responsible for the reviewee’s final manager review.</p>
              <%= form.collection_select :manager_id, @people, :id, :email, { prompt: "Select manager reviewer" }, { class: "mt-4 block w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900 shadow-sm outline-none transition focus:border-orange-500 focus:ring-4 focus:ring-orange-100" } %>
            </div>
          </div>
        </section>

      </div>

      <aside class="space-y-6">
        <section class="rounded-3xl border border-slate-200 bg-slate-50 p-6">
          <p class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-400">Actions</p>
          <h4 class="mt-2 text-lg font-semibold text-slate-900">Save or launch</h4>
          <p class="mt-3 text-sm leading-6 text-slate-500">
            Save a draft to continue later, or launch now once the reviewee and reviewers have been confirmed. Launching will issue secure magic-link requests for the self review, up to three peers, and the manager.
          </p>

          <div class="mt-6 space-y-3">
            <%= form.button "Save Draft", type: "submit", name: "commit_action", value: "draft", class: "inline-flex w-full items-center justify-center rounded-2xl border border-slate-300 bg-white px-4 py-3 text-sm font-semibold text-slate-700 shadow-sm transition hover:border-slate-400 hover:bg-slate-50 hover:text-slate-900" %>
            <%= form.button "Save & Launch", type: "submit", name: "commit_action", value: "launch", class: "inline-flex w-full items-center justify-center rounded-2xl bg-orange-600 px-4 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-orange-700" %>
          </div>
        </section>
      </aside>
    </div>
  <% end %>
</div>
