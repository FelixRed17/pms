<% content_for :title, "Employees" %>

<div class="grid gap-5 sm:grid-cols-2 xl:grid-cols-4">
  <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-card">
    <p class="text-sm font-medium text-slate-500">Employees</p>
    <p class="mt-3 text-4xl font-semibold tracking-tight text-slate-900"><%= @people.count %></p>
  </div>
  <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-card">
    <p class="text-sm font-medium text-slate-500">With User Accounts</p>
    <p class="mt-3 text-4xl font-semibold tracking-tight text-slate-900"><%= @people.count(&:user_id) %></p>
  </div>
  <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-card">
    <p class="text-sm font-medium text-slate-500">Managers Available</p>
    <p class="mt-3 text-4xl font-semibold tracking-tight text-slate-900"><%= @people.count %></p>
  </div>
  <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-card">
    <p class="text-sm font-medium text-slate-500">Peer Pool</p>
    <p class="mt-3 text-4xl font-semibold tracking-tight text-slate-900"><%= @people.count %></p>
  </div>
</div>

<div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-shell">
  <div class="flex items-center justify-between gap-4 border-b border-slate-100 pb-5">
    <div>
      <p class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-400">Employees</p>
      <h3 class="mt-1 text-xl font-semibold text-slate-900">People directory</h3>
    </div>
    <button type="button" class="inline-flex items-center justify-center rounded-2xl bg-slate-900 px-4 py-2.5 text-sm font-semibold text-white transition hover:bg-slate-800">
      Add Employee
    </button>
  </div>

  <div class="mt-6 grid gap-4 md:grid-cols-2 xl:grid-cols-3">
    <% @people.each do |person| %>
      <article class="rounded-3xl border border-slate-200 bg-slate-50 p-5 shadow-card">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-400">Employee</p>
        <h4 class="mt-3 text-lg font-semibold text-slate-900"><%= [person.first_name, person.last_name].join(" ") %></h4>
        <p class="mt-2 text-sm text-slate-500"><%= person.email %></p>
        <p class="mt-4 inline-flex rounded-full bg-white px-3 py-1 text-xs font-medium text-slate-600 shadow-sm">
          <%= person.job_title.presence || "Role pending" %>
        </p>
      </article>
    <% end %>
  </div>
</div>
