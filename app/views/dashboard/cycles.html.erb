<% content_for :title, "Cycles" %>

<div class="grid gap-5 lg:grid-cols-3">
  <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-card">
    <p class="text-sm font-medium text-slate-500">Total Cycles</p>
    <p class="mt-3 text-4xl font-semibold tracking-tight text-slate-900"><%= @review_cycles.count %></p>
  </div>
  <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-card">
    <p class="text-sm font-medium text-slate-500">Active</p>
    <p class="mt-3 text-4xl font-semibold tracking-tight text-slate-900"><%= @review_cycles.count { |cycle| cycle.status == "active" } %></p>
  </div>
  <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-card">
    <p class="text-sm font-medium text-slate-500">Closed</p>
    <p class="mt-3 text-4xl font-semibold tracking-tight text-slate-900"><%= @review_cycles.count { |cycle| cycle.status == "closed" } %></p>
  </div>
</div>

<div class="rounded-3xl border border-slate-200 bg-white shadow-shell">
  <div class="flex items-center justify-between border-b border-slate-200 px-6 py-5">
    <div>
      <p class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-400">Cycles</p>
      <h3 class="mt-1 text-xl font-semibold text-slate-900">Review cycle list</h3>
    </div>
  </div>

  <% if @review_cycles.any? %>
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-slate-200">
        <thead class="bg-slate-50">
          <tr class="text-left text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">
            <th class="px-6 py-4">Cycle</th>
            <th class="px-6 py-4">Reviewee</th>
            <th class="px-6 py-4">Manager</th>
            <th class="px-6 py-4">Peers</th>
            <th class="px-6 py-4">Status</th>
            <th class="px-6 py-4">Requests</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100 bg-white text-sm text-slate-700">
          <% @review_cycles.each do |cycle| %>
            <tr>
              <td class="px-6 py-4">
                <p class="font-semibold text-slate-900"><%= cycle.name %></p>
                <p class="mt-1 text-xs text-slate-500"><%= cycle.start_on %> to <%= cycle.end_on %></p>
              </td>
              <td class="px-6 py-4"><%= [cycle.reviewee.first_name, cycle.reviewee.last_name].join(" ") %></td>
              <td class="px-6 py-4"><%= [cycle.manager.first_name, cycle.manager.last_name].join(" ") %></td>
              <td class="px-6 py-4"><%= cycle.peer_reviewers.count %></td>
              <td class="px-6 py-4">
                <span class="inline-flex rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-slate-600"><%= cycle.status %></span>
              </td>
              <td class="px-6 py-4">
                <div class="space-y-4">
                  <% cycle.review_requests.order(:reviewer_role, :id).each do |review_request| %>
                    <div class="rounded-2xl border border-slate-200 bg-slate-50 p-4">
                      <div class="flex items-start justify-between gap-3">
                        <div>
                          <p class="text-sm font-semibold text-slate-900">
                            <%= review_request.reviewer_role.humanize %>
                            <% if review_request.reviewer %>
                              · <%= review_request.reviewer.full_name %>
                            <% end %>
                          </p>
                          <p class="mt-1 text-xs text-slate-500"><%= review_request.recipient_email %></p>
                          <p class="mt-2 text-xs uppercase tracking-[0.18em] text-slate-400">
                            Delivery <span class="font-semibold text-slate-600"><%= review_request.delivery_status %></span>
                            <% if review_request.last_sent_at.present? %>
                              · Sent <%= review_request.last_sent_at.to_fs(:short) %>
                            <% end %>
                          </p>
                          <% last_audit = review_request.review_request_audits.order(:created_at).last %>
                          <% if last_audit&.reissued? %>
                            <p class="mt-2 text-xs text-slate-500">Last reissue reason: <%= last_audit.reason %></p>
                          <% end %>
                          <% if review_request.last_delivery_error.present? %>
                            <p class="mt-2 text-xs text-orange-600"><%= review_request.last_delivery_error %></p>
                          <% end %>
                        </div>
                      </div>

                      <% unless review_request.completed? %>
                        <%= form_with url: reissue_review_request_path(review_request), method: :post, class: "mt-4 space-y-2" do |form| %>
                          <%= form.text_field :reason, name: "review_request[reason]", placeholder: "Reason for reissue", required: true, class: "block w-full rounded-2xl border border-slate-200 bg-white px-3 py-2 text-sm text-slate-900 shadow-sm outline-none transition focus:border-orange-500 focus:ring-4 focus:ring-orange-100" %>
                          <%= form.submit "Reissue Link", class: "inline-flex items-center justify-center rounded-2xl border border-slate-300 bg-white px-3 py-2 text-xs font-semibold uppercase tracking-[0.18em] text-slate-700 shadow-sm transition hover:border-slate-400 hover:bg-slate-100 hover:text-slate-900" %>
                        <% end %>
                      <% end %>
                    </div>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="px-6 py-12 text-center">
      <p class="text-lg font-semibold text-slate-900">No review cycles yet.</p>
      <p class="mt-2 text-sm text-slate-500">Use Launch New Cycle to configure the first cycle.</p>
    </div>
  <% end %>
</div>
