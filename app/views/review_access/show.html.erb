<% content_for :title, "Review Questions" %>

<div class="mx-auto min-h-screen max-w-4xl px-4 py-10 sm:px-6 lg:px-8">
  <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-shell sm:p-8">
    <div class="border-b border-slate-200 pb-6">
      <p class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-400">Secure Review Access</p>
      <h1 class="mt-2 text-3xl font-semibold text-slate-900"><%= @review_request.questionnaire_heading %></h1>
      <p class="mt-3 max-w-2xl text-sm leading-6 text-slate-500">
        Your magic link verified your access. Submit your questionnaire without logging in. The questionnaire type is inferred from your secure review request.
      </p>
      <p class="mt-2 text-sm font-medium text-slate-700">Your secure review link is active.</p>
    </div>

    <section class="mt-8 rounded-3xl border border-slate-200 bg-slate-50 p-6">
      <fieldset>
        <legend class="text-sm font-semibold uppercase tracking-[0.18em] text-slate-500">Scoring scale</legend>
        <div class="mt-4 grid gap-3 md:grid-cols-2">
          <% QuestionnaireCatalog::SCORE_SCALE.each do |scale_item| %>
            <div class="rounded-2xl border border-slate-200 bg-white px-4 py-4">
              <p class="text-sm font-semibold text-slate-900"><%= scale_item[:value] %> · <%= scale_item[:label] %></p>
              <p class="mt-1 text-sm leading-6 text-slate-500"><%= scale_item[:definition] %></p>
            </div>
          <% end %>
        </div>
      </fieldset>
    </section>

    <% if @review_submission.review_answers.any? %>
      <%= form_with model: @review_submission, url: submit_review_access_path(token: params[:token]), method: :post, local: true, class: "mt-8 space-y-6" do |form| %>
        <%= form.fields_for :review_answers do |answer_fields| %>
          <% question_template = answer_fields.object.question_template %>
          <section class="rounded-3xl border border-slate-200 bg-slate-50 p-6">
            <div class="flex items-start justify-between gap-4">
              <div>
                <p class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-400">Questionnaire section</p>
                <h2 class="mt-2 text-lg font-semibold text-slate-900"><%= question_template.title %></h2>
              </div>
              <span class="rounded-full bg-white px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-slate-500"><%= question_template.question_type.humanize %></span>
            </div>

            <%= answer_fields.hidden_field :question_template_id %>

            <% if question_template.description.present? %>
              <% guidance_points = question_template.guidance_points %>
              <div class="mt-4 rounded-2xl border border-dashed border-slate-300 bg-white px-4 py-4">
                <% if guidance_points.many? %>
                  <ul class="space-y-2 text-sm leading-6 text-slate-500">
                    <% guidance_points.each do |point| %>
                      <li><%= point %></li>
                    <% end %>
                  </ul>
                <% else %>
                  <p class="text-sm leading-6 text-slate-500"><%= question_template.description %></p>
                <% end %>
              </div>
            <% end %>

            <div class="mt-5 space-y-5">
              <% if question_template.requires_score? %>
                <fieldset>
                  <legend class="text-sm font-medium text-slate-700">Score</legend>
                  <div class="mt-3 grid gap-3 sm:grid-cols-3 lg:grid-cols-6">
                    <% QuestionnaireCatalog::SCORE_SCALE.each do |scale_item| %>
                      <label class="flex cursor-pointer items-center justify-center rounded-2xl border border-slate-200 bg-white px-4 py-4 text-sm font-semibold text-slate-700 transition hover:border-orange-300 hover:bg-orange-50 has-[:checked]:border-orange-500 has-[:checked]:bg-orange-50 has-[:checked]:text-orange-700">
                        <%= answer_fields.radio_button :score, scale_item[:value], class: "sr-only" %>
                        <span><%= scale_item[:value] %></span>
                      </label>
                    <% end %>
                  </div>
                </fieldset>
              <% end %>

              <% if question_template.requires_comment? %>
                <div>
                  <%= answer_fields.label :comment, "Comment", class: "mb-2 block text-sm font-medium text-slate-700" %>
                  <%= answer_fields.text_area :comment, rows: 5, class: "block w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm text-slate-900 shadow-sm outline-none transition focus:border-orange-500 focus:ring-4 focus:ring-orange-100", placeholder: "Share examples, context, and specific feedback..." %>
                </div>
              <% end %>
            </div>
          </section>
        <% end %>

        <div class="flex justify-end border-t border-slate-200 pt-6">
          <%= form.submit "Submit Review", class: "inline-flex items-center justify-center rounded-2xl bg-orange-600 px-5 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-orange-700" %>
        </div>
      <% end %>
    <% else %>
      <div class="mt-8 rounded-3xl border border-dashed border-slate-300 bg-slate-50 p-6">
        <h2 class="text-lg font-semibold text-slate-900">No questions available</h2>
        <p class="mt-2 text-sm leading-6 text-slate-500">
          No system questionnaire is available for this reviewer role, so the review form cannot be completed.
        </p>
      </div>
    <% end %>
  </div>
</div>
