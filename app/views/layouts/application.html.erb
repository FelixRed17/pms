<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Pms" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Pms">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= javascript_tag nonce: true do %>
      tailwind = {
        config: {
          theme: {
            extend: {
              fontFamily: {
                sans: ["Geist Mono", "ui-monospace", "SFMono-Regular", "Menlo", "monospace"],
                mono: ["Geist Mono", "ui-monospace", "SFMono-Regular", "Menlo", "monospace"]
              },
              colors: {
                brand: {
                  500: "#f25103",
                  600: "#d9480f",
                  700: "#b63a08"
                },
                frame: {
                  950: "#050505",
                  925: "#090909",
                  900: "#101010",
                  850: "#141414",
                  800: "#1a1a1a",
                  700: "#262626",
                  600: "#3a3a3a"
                }
              },
              boxShadow: {
                shell: "0 0 0 1px rgba(242, 81, 3, 0.12), 0 24px 70px rgba(0, 0, 0, 0.55)",
                card: "0 12px 30px rgba(0, 0, 0, 0.28)"
              }
            }
          }
        }
      }
    <% end %>
    <script src="https://cdn.tailwindcss.com"></script>
    <%= stylesheet_link_tag "styles", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen bg-frame-950 font-mono text-white antialiased selection:bg-brand-500/30 selection:text-white">
    <div class="noise"></div>
    <% if @render_dashboard_shell %>
      <%= render "shared/dashboard_shell" %>
    <% else %>
      <%= yield %>
    <% end %>
  </body>
</html>
