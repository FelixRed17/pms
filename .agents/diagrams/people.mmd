        B --> C["System requests list of employees"]
        C --> D{"What does HR want to do?"}

        D -- Browse Existing People --> E["Display list of existing employees"]
        E --> F["HR selects an employee"]
        F --> G["Open selected employee profile"]
        G --> H["HR clicks 'Create Review Cycle' for selected employee"]
        H --> I["Request review cycle creation"]

