        P --> I

        I --> Q(["End: Review cycle created"])
    end

    subgraph Backend["Rails Backend & Storage"]
        C --> R["Query Employee records"]
        F --> S["Fetch employee details"]
        H --> T["POST /review_cycles with employee_id"]
        L --> U["Validate employee params"]
        M --> V["POST /employees"]
        V --> W["Create Employee record"]
        W --> X["Return new employee"]
        P --> T
        T --> Y["Create ReviewCycle record"]
        Y --> DB[(Database)]
    end

    DB --> R
    DB --> S
